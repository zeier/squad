---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Your AI Development Team">
  <Header />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-squad-50 via-white to-squad-100/50 dark:from-squad-950/30 dark:via-surface-950 dark:to-surface-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(99,102,241,0.1),transparent_50%)] dark:bg-[radial-gradient(ellipse_at_top,rgba(99,102,241,0.15),transparent_50%)]"></div>
    <div class="relative max-w-7xl mx-auto px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-squad-100 dark:bg-squad-900/40 text-squad-700 dark:text-squad-300 px-3 py-1 rounded-full text-sm font-medium mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-squad-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-squad-500"></span>
          </span>
          Alpha — Rapidly evolving
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-surface-900 dark:text-white mb-6">
          Your AI<br />
          <span class="bg-gradient-to-r from-squad-600 to-squad-400 bg-clip-text text-transparent">Development Team</span>
        </h1>

        <p class="text-lg sm:text-xl text-surface-600 dark:text-surface-300 mb-8 leading-relaxed max-w-2xl mx-auto">
          Describe what you're building. Get a team of specialists that live in your repo.
          Squad is a multi-agent runtime for GitHub Copilot — agents fan out, build in parallel,
          and land pull requests in minutes.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`${base}docs/get-started/installation/`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-squad-600 hover:bg-squad-700 text-white font-medium transition-colors shadow-lg shadow-squad-600/20"
          >
            Get Started
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="https://github.com/bradygaster/squad"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-surface-300 dark:border-surface-700 text-surface-700 dark:text-surface-300 hover:bg-surface-50 dark:hover:bg-surface-800 font-medium transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Try This -->
  <section class="py-16 bg-surface-50 dark:bg-surface-900/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-center text-surface-900 dark:text-white mb-8">Try this in Copilot</h2>
      <div class="bg-surface-900 dark:bg-surface-800 rounded-xl overflow-hidden shadow-2xl">
        <div class="flex items-center gap-2 px-4 py-3 bg-surface-800 dark:bg-surface-700 border-b border-surface-700">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <span class="text-xs text-surface-400 ml-2">Copilot Chat</span>
        </div>
        <div class="p-6 font-mono text-sm">
          <p class="text-surface-400 mb-4">
            <span class="text-squad-400">you:</span> Team, build the recipe listing page. We need an API endpoint
            that returns recipes and a React component that displays them.
          </p>
          <div class="space-y-1.5 text-surface-300">
            <p><span class="text-yellow-400">🏗️ Flight</span>    — reviewing requirements, defining API contract</p>
            <p><span class="text-blue-400">⚛️ EECOM</span>     — building RecipeList component</p>
            <p><span class="text-green-400">🔧 CAPCOM</span>    — creating GET /api/recipes endpoint</p>
            <p><span class="text-purple-400">🧪 FIDO</span>     — writing test cases from requirements</p>
            <p><span class="text-surface-500">📋 Scribe</span>    — logging decisions</p>
          </div>
          <p class="text-surface-500 mt-4 text-xs">Five agents, working at the same time. Results land in minutes, not hours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-surface-900 dark:text-white mb-4">Why Squad?</h2>
        <p class="text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto">
          Move multi-agent orchestration from prompts into code. Enforced rules, persistent teams, parallel execution.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group p-6 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-squad-300 dark:hover:border-squad-700 hover:shadow-lg hover:shadow-squad-100/50 dark:hover:shadow-squad-900/20 transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-squad-100 dark:bg-squad-900/40 flex items-center justify-center mb-4 text-xl">🚀</div>
          <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">Parallel AI Teamwork</h3>
          <p class="text-surface-600 dark:text-surface-400 text-sm leading-relaxed">Give a task to the team and multiple agents fan out simultaneously. No waiting in line — results land in minutes.</p>
        </div>

        <div class="group p-6 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-squad-300 dark:hover:border-squad-700 hover:shadow-lg hover:shadow-squad-100/50 dark:hover:shadow-squad-900/20 transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-squad-100 dark:bg-squad-900/40 flex items-center justify-center mb-4 text-xl">🧠</div>
          <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">Persistent Memory</h3>
          <p class="text-surface-600 dark:text-surface-400 text-sm leading-relaxed">Agents remember decisions and conventions across sessions. Your team gets smarter every time you work together.</p>
        </div>

        <div class="group p-6 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-squad-300 dark:hover:border-squad-700 hover:shadow-lg hover:shadow-squad-100/50 dark:hover:shadow-squad-900/20 transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-squad-100 dark:bg-squad-900/40 flex items-center justify-center mb-4 text-xl">🐙</div>
          <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">GitHub-Native</h3>
          <p class="text-surface-600 dark:text-surface-400 text-sm leading-relaxed">Squad lives in your repo as <code class="bg-surface-100 dark:bg-surface-800 px-1 py-0.5 rounded text-xs">.squad/</code>. Commit it, share it, clone it. Your team travels with your code.</p>
        </div>

        <div class="group p-6 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-squad-300 dark:hover:border-squad-700 hover:shadow-lg hover:shadow-squad-100/50 dark:hover:shadow-squad-900/20 transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-squad-100 dark:bg-squad-900/40 flex items-center justify-center mb-4 text-xl">🛡️</div>
          <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">Built-in Governance</h3>
          <p class="text-surface-600 dark:text-surface-400 text-sm leading-relaxed">File-write guards, PII scrubbing, reviewer lockout — rules enforced in code, not suggestions in prompts.</p>
        </div>

        <div class="group p-6 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-squad-300 dark:hover:border-squad-700 hover:shadow-lg hover:shadow-squad-100/50 dark:hover:shadow-squad-900/20 transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-squad-100 dark:bg-squad-900/40 flex items-center justify-center mb-4 text-xl">⚡</div>
          <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">SDK-First Design</h3>
          <p class="text-surface-600 dark:text-surface-400 text-sm leading-relaxed">Define your team in TypeScript with <code class="bg-surface-100 dark:bg-surface-800 px-1 py-0.5 rounded text-xs">squad.config.ts</code>. Typed, testable, version-controlled orchestration.</p>
        </div>

        <div class="group p-6 rounded-xl border border-surface-200 dark:border-surface-800 hover:border-squad-300 dark:hover:border-squad-700 hover:shadow-lg hover:shadow-squad-100/50 dark:hover:shadow-squad-900/20 transition-all duration-200">
          <div class="w-10 h-10 rounded-lg bg-squad-100 dark:bg-squad-900/40 flex items-center justify-center mb-4 text-xl">🔌</div>
          <h3 class="text-lg font-semibold text-surface-900 dark:text-white mb-2">Extensible</h3>
          <p class="text-surface-600 dark:text-surface-400 text-sm leading-relaxed">Plugins, marketplace, MCP integration, custom hooks — extend Squad to fit your workflow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Inside -->
  <section class="py-16 bg-surface-50 dark:bg-surface-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-surface-900 dark:text-white mb-12">Explore the Docs</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href={`${base}docs/get-started/installation/`} class="group p-5 rounded-xl bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-squad-400 dark:hover:border-squad-600 hover:shadow-md transition-all">
          <h3 class="font-semibold text-surface-900 dark:text-white mb-1 group-hover:text-squad-600 dark:group-hover:text-squad-400 transition-colors">Get Started</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400">Install and run your first session in 60 seconds</p>
        </a>

        <a href={`${base}docs/features/team-setup/`} class="group p-5 rounded-xl bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-squad-400 dark:hover:border-squad-600 hover:shadow-md transition-all">
          <h3 class="font-semibold text-surface-900 dark:text-white mb-1 group-hover:text-squad-600 dark:group-hover:text-squad-400 transition-colors">Features</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400">Parallel work, memory, routing, governance, and more</p>
        </a>

        <a href={`${base}docs/reference/cli/`} class="group p-5 rounded-xl bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-squad-400 dark:hover:border-squad-600 hover:shadow-md transition-all">
          <h3 class="font-semibold text-surface-900 dark:text-white mb-1 group-hover:text-squad-600 dark:group-hover:text-squad-400 transition-colors">Reference</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400">CLI commands, SDK API, configuration</p>
        </a>

        <a href={`${base}docs/scenarios/existing-repo/`} class="group p-5 rounded-xl bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 hover:border-squad-400 dark:hover:border-squad-600 hover:shadow-md transition-all">
          <h3 class="font-semibold text-surface-900 dark:text-white mb-1 group-hover:text-squad-600 dark:group-hover:text-squad-400 transition-colors">Scenarios</h3>
          <p class="text-sm text-surface-500 dark:text-surface-400">Real-world patterns for your project type</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick install -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-surface-900 dark:text-white mb-4">Ready to get started?</h2>
      <p class="text-lg text-surface-600 dark:text-surface-400 mb-8">Install Squad and have your AI team up and running in under a minute.</p>
      <div class="bg-surface-900 dark:bg-surface-800 rounded-xl p-6 text-left font-mono text-sm shadow-2xl">
        <p class="text-surface-400 mb-2"># Install globally</p>
        <p class="text-green-400">$ npm install -g @bradygaster/squad-cli</p>
        <p class="text-surface-400 mt-4 mb-2"># Initialize in your project</p>
        <p class="text-green-400">$ cd your-project && squad init</p>
        <p class="text-surface-400 mt-4 mb-2"># Start the interactive shell</p>
        <p class="text-green-400">$ squad shell</p>
      </div>
      <div class="mt-8">
        <a
          href={`${base}docs/get-started/installation/`}
          class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-squad-600 hover:bg-squad-700 text-white font-medium transition-colors shadow-lg shadow-squad-600/20"
        >
          Read the Installation Guide
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
